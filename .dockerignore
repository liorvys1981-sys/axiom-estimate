# Version control
.git
.gitignore
.github

# Python cache
__pycache__
*.pyc
*.pyo
*.pyd
*.egg-info
.eggs

# Virtual environments
.venv
venv
env

# Testing & coverage
.pytest_cache
.coverage
htmlcov
.tox

# Linting caches
.ruff_cache
.mypy_cache

# Local environment files (never bake secrets into the image)
.env
.env.*
!.env.example

# Local databases
*.db
*.sqlite
*.sqlite3

# Editor / OS artefacts
.DS_Store
.idea
.vscode
*.swp
*.swo

# Documentation (not needed at runtime)
README.md
docs/

# Infrastructure-as-code (not needed at runtime)
k8s/
terraform/
scripts/

# Build artefacts
dist/
build/

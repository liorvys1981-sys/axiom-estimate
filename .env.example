# ─── Application ──────────────────────────────────────────────────────────────
APP_ENV=development
APP_NAME=AXIOM ESTIMATE
APP_VERSION=2.0.0
LOG_LEVEL=INFO
SERVICE_NAME=api-gateway
SERVICE_PORT=8000

# ─── Database ─────────────────────────────────────────────────────────────────
# Development: SQLite (no external DB required)
DATABASE_URL=sqlite:///./axiom_dev.db
# Production: set to your Railway PostgreSQL URL
# DATABASE_URL=postgresql://user:password@host:5432/axiom_prod

# ─── Authentication ───────────────────────────────────────────────────────────
# IMPORTANT: Replace with a cryptographically random secret in production.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=dev-insecure-change-me
JWT_EXPIRE_MINUTES=60

# ─── Feature Flags ────────────────────────────────────────────────────────────
GUARDIAN_ENABLED=false

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Development: allow localhost origins
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]
# Production: restrict to your actual domain
# CORS_ORIGINS=["https://axiomestimate.com"]
